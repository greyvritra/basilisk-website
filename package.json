{
  "name": "basilisk-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/website-build.mjs",
    "start": "npx serve@latest out -l 3000",
    "lint": "next lint",
    "website:build": "node scripts/website-build.mjs",
    "website:public": "node scripts/website-public-check.mjs",
    "public-demo": "node scripts/public-demo-check.mjs",
    "first-run": "node scripts/first-run-check.mjs",
    "external-docs": "node scripts/external-docs-check.mjs",
    "distribution-policy": "node scripts/distribution-policy-check.mjs",
    "release-bundle": "node scripts/release-bundle-check.mjs",
    "feedback-loop": "node scripts/feedback-loop-check.mjs",
    "integration-showcase": "node scripts/integration-showcase-check.mjs",
    "qa:public-demo": "npm run website:build && node scripts/public-demo-check.mjs --require-pass",
    "qa:first-run": "npm run website:build && node scripts/first-run-check.mjs --require-pass",
    "qa:external-docs": "npm run website:build && node scripts/external-docs-check.mjs --require-pass",
    "qa:distribution-policy": "npm run website:build && node scripts/distribution-policy-check.mjs --require-pass",
    "qa:release-bundle": "npm run website:build && node scripts/release-bundle-check.mjs --require-pass",
    "qa:feedback-loop": "npm run website:build && node scripts/feedback-loop-check.mjs --require-pass",
    "qa:integration-showcase": "npm run website:build && node scripts/integration-showcase-check.mjs --require-pass",
    "qa:website-public": "npm run website:build && node scripts/website-public-check.mjs --require-pass"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.12.5",
    "lucide-react": "^1.8.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0"
  }
}
